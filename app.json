{
  "expo": {
    "name": "loc-jobs",
    "slug": "loc-jobs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "locjobs",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.locjobs.app",
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "LocJobs uses your location to find nearby jobs."
      }
    },
    "android": {
      "package": "com.locjobs.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAE_iQ_nuJPQy_VYKnt8nFWvtYHbBFwF_g"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "LocJobs uses your location to find nearby jobs.",
          "locationWhenInUsePermission": "LocJobs uses your location to find nearby jobs."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain"
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "686b2b39-0be3-4a1f-91c9-c0c8f587c128"
      }
    },
    "runtimeVersion": "1.0.0"
  }
}
